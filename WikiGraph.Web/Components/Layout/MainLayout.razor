@inherits LayoutComponentBase

<div class="shell">
    <aside class="shell-sidebar">
        <div class="brand">
            <div class="brand-mark">WG</div>
            <div>
                <div class="brand-title">WikiGraph</div>
                <div class="brand-subtitle">Wikipedia RAG workspace</div>
            </div>
        </div>
        <NavMenu />
    </aside>
    <main class="shell-main">
        <section class="shell-header">
            <div>
                <p class="eyebrow">Research assistant</p>
                <h1>Topic graphs, citations, and study-guide notes from Wikipedia.</h1>
            </div>
            <a class="header-link" href="https://www.wikipedia.org/" target="_blank">Open Wikipedia</a>
        </section>
        <article class="shell-content">
            @Body
        </article>
    </main>
</div>
