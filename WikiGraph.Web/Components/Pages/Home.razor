@page "/"
@using WikiGraph.Contracts

<PageTitle>WikiGraph</PageTitle>

@code {
    private readonly List<SessionSummary> sessions =
    [
        new("sess-001", "Artificial intelligence ethics", DateTime.UtcNow.AddDays(-2), DateTime.UtcNow.AddHours(-3)),
        new("sess-002", "Roman architecture", DateTime.UtcNow.AddDays(-1), DateTime.UtcNow.AddHours(-5)),
        new("sess-003", "Climate adaptation", DateTime.UtcNow.AddHours(-12), DateTime.UtcNow.AddHours(-1))
    ];

    private readonly List<MessageDto> messages =
    [
        new("user", "Build a study guide for climate adaptation policy.", DateTime.UtcNow.AddMinutes(-25)),
        new("assistant", "Focus on resilience, mitigation, and governance.", DateTime.UtcNow.AddMinutes(-24)),
        new("user", "Add a graph around coastal cities and flood risk.", DateTime.UtcNow.AddMinutes(-12)),
        new("assistant", "Linked concepts: sea level rise, zoning, and emergency planning.", DateTime.UtcNow.AddMinutes(-11))
    ];

    private readonly IReadOnlyList<CitationDto> citations =
    [
        new("Climate change adaptation", "https://en.wikipedia.org/wiki/Climate_change_adaptation"),
        new("Sea level rise", "https://en.wikipedia.org/wiki/Sea_level_rise", "Background"),
        new("Urban resilience", "https://en.wikipedia.org/wiki/Urban_resilience", "Applications")
    ];

    private readonly IReadOnlyList<GraphDto> graphs =
    [
        new("Climate adaptation",
            [
                new GraphNodeDto("topic", "Climate adaptation", 5),
                new GraphNodeDto("coastal", "Coastal cities", 4),
                new GraphNodeDto("risk", "Flood risk", 3),
                new GraphNodeDto("policy", "Policy response", 2)
            ],
            [
                new GraphEdgeDto("topic", "coastal", "connects"),
                new GraphEdgeDto("topic", "risk", "frames"),
                new GraphEdgeDto("topic", "policy", "supports")
            ])
    ];
}

<div class="dashboard">
    @* This server-rendered shell mirrors the same sessions/thread/citations/graph composition as the WASM client. *@
    <section class="panel sidebar-panel" id="sessions">
        <div class="panel-title">Sessions</div>
        @foreach (var session in sessions)
        {
            <article class="session-card">
                <strong>@session.Title</strong>
                <span>@session.LastAccessUtc.ToLocalTime().ToString("g")</span>
            </article>
        }
    </section>

    <section class="panel chat-panel" id="thread">
        <div class="panel-title">Chat thread</div>
        @foreach (var message in messages)
        {
            <article class="message message-@message.Role">
                <div class="message-role">@message.Role</div>
                <p>@message.Content</p>
            </article>
        }
        <form class="composer">
            <input class="composer-input" value="Explain the topic and produce a graph." aria-label="Prompt" />
            <button class="composer-button" type="button">Send</button>
        </form>
    </section>

    <section class="panel detail-panel">
        <div id="graphs" class="panel-title">Citations and graph</div>
        <div class="citation-list">
            @foreach (var citation in citations)
            {
                <a class="citation-card" href="@citation.Url" target="_blank">
                    <strong>@citation.Title</strong>
                    <span>@citation.Section</span>
                </a>
            }
        </div>
        @foreach (var graph in graphs)
        {
            <div class="graph-card">
                <h2>@graph.Topic</h2>
                <div class="graph-nodes">
                    @foreach (var node in graph.Nodes)
                    {
                        <span class="graph-node graph-node-@node.Weight">@node.Label</span>
                    }
                </div>
            </div>
        }
    </section>
</div>
