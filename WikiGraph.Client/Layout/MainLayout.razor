@using WikiGraph.Client.Pages
@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
<div class="getUrl">
    <aside class="sidebar">
        <div class="brand">
            <div class="logo">WG</div>
            <div>
                <div class="brand-title">WikiGraph</div>
                <div class="brand-subtitle">Research chat client</div>
            </div>
        </div>
        <p class="sidebar-copy">Trace answers back to citations and relationship graphs built from Wikipedia context.</p>
        <NavMenu/>
        <div class="sidebar-footer">
            <div class="sidebar-note">API target <code>localhost:5052</code></div>
        </div>
    </aside>
    <main class="main">
        @Body
    </main>
</div>

@code{
    private string getUrl(){

        string currentPage = NavigationManager.Uri;
        if(currentPage.ToLower().Contains("Session")){return "session";}
        else {return "home";}
    }

}


