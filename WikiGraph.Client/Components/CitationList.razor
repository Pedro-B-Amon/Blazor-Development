@if (Citations.Count == 0)
{
    <div class="empty-card">
        <strong>No citations yet</strong>
        <p class="muted">Source passages will appear after the first assistant response.</p>
    </div>
}
else
{
    <div class="citations">
        @foreach (var citation in Citations)
        {
            <a class="citation" href="@citation.Url" target="_blank" rel="noreferrer">
                <div class="citation-copy">
                    <strong>@citation.Title</strong>
                    <span>@(string.IsNullOrWhiteSpace(citation.Section) ? "Wikipedia excerpt" : citation.Section)</span>
                </div>
                <span class="citation-link">Open</span>
            </a>
        }
    </div>
}

@code {
    [Parameter]
    public IReadOnlyList<CitationDto> Citations { get; set; } = [];
}
