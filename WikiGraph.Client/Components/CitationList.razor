@if (Citations.Count == 0)
{
    <div class="empty-card">
        <strong>No citations yet</strong>
        <p class="muted">Source passages will appear after the first assistant response.</p>
    </div>
}
else
{
    <div class="citations-dropdowns">
        @foreach (var citation in Citations)
        {
            <details class="dropdown-card">
                <summary class="dropdown-summary">
                    <div class="dropdown-copy">
                        <strong>@citation.Title</strong>
                        <span>
                            @(string.IsNullOrWhiteSpace(citation.Section)
                                ? "Wikipedia excerpt"
                                : citation.Section)
                        </span>
                    </div>
                    <span class="dropdown-icon">⌄</span>
                </summary>

                <div class="dropdown-body">
                    <a href="@citation.Url" target="_blank" rel="noreferrer" class="dropdown-link">
                        Open source
                    </a>
                </div>
            </details>
        }
    </div>
}

@code {
    [Parameter]
    public IReadOnlyList<CitationDto> Citations { get; set; } = [];
}
