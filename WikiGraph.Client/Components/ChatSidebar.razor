<section class="card session-card" id="sessions">
    <div class="panel-header">
        <div>
            <p class="eyebrow">Library</p>
            <h2>Sessions</h2>
        </div>
        <span class="count-pill">@Sessions.Count</span>
    </div>
    @if (Sessions.Count == 0)
    {
        <div class="empty-card">
            <strong>No sessions yet</strong>
            <p class="muted">Run a query to create your first research thread.</p>
        </div>
    }
    else
    {
        <div class="session-list">
            @foreach (var session in Sessions)
            {
                <button class="session-button @(session.SessionId == SelectedSessionId ? "selected" : "")" @onclick="@(() => OnSelectSession.InvokeAsync(session.SessionId))">
                    <span class="session-title">@session.Title</span>
                    <span class="session-meta">Updated @session.LastAccessUtc.ToLocalTime().ToString("MMM d, h:mm tt")</span>
                </button>
            }
        </div>
    }
</section>

@code {
    [Parameter]
    public IReadOnlyList<SessionSummary> Sessions { get; set; } = [];

    [Parameter]
    public string? SelectedSessionId { get; set; }

    [Parameter]
    public EventCallback<string> OnSelectSession { get; set; }
}
