<section class="card thread-card" id="thread">
    <div class="panel-header">
        <div>
            <p class="eyebrow">Chat workspace</p>
            <h2>Conversation</h2>
        </div>
        <span class="status-pill @(IsBusy ? "busy" : "ready")">@(IsBusy ? "Syncing" : "Ready")</span>
    </div>

    <div class="thread-stream">
        @if (Messages.Count == 0)
        {
            <div class="empty-card thread-empty">
                <strong>Start with a question</strong>
                <p class="muted">Try a topic like climate adaptation or paste a Wikipedia article to seed the response.</p>
            </div>
        }
        else
        {
            @foreach (var message in Messages)
            {
                <MessageView Message="message" />
            }
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="error-banner">@ErrorMessage</div>
    }

    <form class="composer" @onsubmit="HandleSubmit" @onsubmit:preventDefault="true">
        <label class="input-shell">
            <span>Prompt</span>
            <textarea class="composer-input composer-textarea"
                      value="@Prompt"
                      @oninput="HandlePromptChanged"
                      aria-label="Prompt"
                      placeholder="Ask about a topic, concept, person, or event"
                      disabled="@IsBusy"></textarea>
        </label>

        <label class="input-shell">
            <span>Wikipedia URL</span>
            <input class="composer-input"
                   value="@SourceUrl"
                   @oninput="HandleSourceUrlChanged"
                   aria-label="Wikipedia URL"
                   placeholder="https://en.wikipedia.org/wiki/..."
                   disabled="@IsBusy" />
        </label>

        <div class="composer-actions">
            <p class="muted">Enter a prompt, a Wikipedia URL, or both.</p>
            <button class="send" type="submit" disabled="@IsBusy">@(IsBusy ? "Sending..." : "Send message")</button>
        </div>
    </form>
</section>

@code {
    [Parameter]
    public IReadOnlyList<MessageDto> Messages { get; set; } = [];

    [Parameter]
    public string Prompt { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> PromptChanged { get; set; }

    [Parameter]
    public string SourceUrl { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> SourceUrlChanged { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public string? ErrorMessage { get; set; }

    [Parameter]
    public EventCallback OnSubmit { get; set; }

    private Task HandleSubmit() => OnSubmit.InvokeAsync();

    private Task HandlePromptChanged(ChangeEventArgs args) =>
        PromptChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    private Task HandleSourceUrlChanged(ChangeEventArgs args) =>
        SourceUrlChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);
}
