<article class="message @ResolveRoleClass(Message.Role)">
    <div class="message-avatar">@ResolveAvatar(Message.Role)</div>
    <div class="message-bubble">
        <div class="message-meta">
            <span class="role">@ResolveRoleLabel(Message.Role)</span>
            <span class="timestamp">@Message.CreatedUtc.ToLocalTime().ToString("MMM d, h:mm tt")</span>
        </div>
        <p>@Message.Content</p>
    </div>
</article>

@code {
    [Parameter, EditorRequired]
    public required MessageDto Message { get; set; }

    private static string ResolveAvatar(string role) =>
        role.Trim().Equals("user", StringComparison.OrdinalIgnoreCase) ? "You" : "AI";

    private static string ResolveRoleClass(string role) =>
        role.Trim().Equals("user", StringComparison.OrdinalIgnoreCase) ? "user" : "assistant";

    private static string ResolveRoleLabel(string role) =>
        role.Trim().Equals("user", StringComparison.OrdinalIgnoreCase) ? "You" : "Assistant";
}
