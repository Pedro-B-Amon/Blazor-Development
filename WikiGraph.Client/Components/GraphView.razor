@if (Graphs.Count == 0)
{
    <div class="empty-card">
        <strong>No graph yet</strong>
        <p class="muted">Topic graphs appear once the assistant extracts relationships from the session context.</p>
    </div>
}
else
{
    @foreach (var graph in Graphs)
    {
        <div class="graph">
            <div class="graph-header">
                <div>
                    <p class="eyebrow">Topic map</p>
                    <h3>@graph.Topic</h3>
                </div>
                <span class="graph-count">@graph.Nodes.Count node@(graph.Nodes.Count == 1 ? string.Empty : "s")</span>
            </div>
            <div class="nodes">
                @foreach (var node in graph.Nodes)
                {
                    <span class="node">@node.Label</span>
                }
            </div>
            <div class="edges">
                @foreach (var edge in graph.Edges)
                {
                    <div class="edge">
                        <span class="edge-source">@ResolveLabel(graph, edge.Source)</span>
                        <span class="edge-relation">@edge.Relation</span>
                        <span class="edge-target">@ResolveLabel(graph, edge.Target)</span>
                    </div>
                }
            </div>
        </div>
    }
}

@code {
    [Parameter]
    public IReadOnlyList<GraphDto> Graphs { get; set; } = [];

    private static string ResolveLabel(GraphDto graph, string nodeId) =>
        graph.Nodes.FirstOrDefault(node => node.Id == nodeId)?.Label ?? nodeId;
}
