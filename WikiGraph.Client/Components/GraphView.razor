@inject IJSRuntime JSRuntime

<div class="session-panel details-panel">
    <div class="details-header">
        <p>@(CurrentGraph?.Topic ?? "Session details")</p>

        <div class="details-toggle">
            <button type="button"
                    class="toggle-button @(activeView == DetailView.Citations ? "active" : "")"
                    @onclick="() => SetView(DetailView.Citations)">
                Citations
            </button>

            <button type="button"
                    class="toggle-button @(activeView == DetailView.Graph ? "active" : "")"
                    @onclick="() => SetView(DetailView.Graph)">
                Graph
            </button>
        </div>
    </div>
}
else
{
    <div class="graph-dropdowns">
        @foreach (var graph in Graphs)
        {
            <details class="dropdown-card">
                <summary class="dropdown-summary">
                    <div class="dropdown-copy">
                        <p class="eyebrow">Topic map</p>
                        <strong>@graph.Topic</strong>
                        <span>@graph.Nodes.Count node@(graph.Nodes.Count == 1 ? string.Empty : "s")</span>
                    </div>
                    <span class="dropdown-icon">⌄</span>
                </summary>

                <div class="dropdown-body">
                    <div class="nodes">
                        @foreach (var node in graph.Nodes)
                        {
                            <span class="node">@node.Label</span>
                        }
                    </div>

                    <div class="edges">
                        @foreach (var edge in graph.Edges)
                        {
                            <div class="edge">
                                <span class="edge-source">@ResolveLabel(graph, edge.Source)</span>
                                <span class="edge-relation">@edge.Relation</span>
                                <span class="edge-target">@ResolveLabel(graph, edge.Target)</span>
                            </div>
                        }
                    </div>
                </div>
            </details>
        }
    </div>
}

@code {
    [Parameter]
    public GraphDto? CurrentGraph { get; set; }

    [Parameter]
    public EventCallback<GraphDto?> CurrentGraphChanged { get; set; }

    [Parameter]
    public IReadOnlyList<GraphDto> Graphs { get; set; } = [];

    [Parameter]
    public IReadOnlyList<CitationDto> Citations { get; set; } = [];

    private ElementReference canvasReference;
    private string? _lastTopic;
    private DetailView activeView = DetailView.Citations;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (activeView != DetailView.Graph || CurrentGraph is null)
            return;

        if (CurrentGraph.Topic == _lastTopic)
            return;

        _lastTopic = CurrentGraph.Topic;

        await JSRuntime.InvokeVoidAsync("graphCanvas.renderGraph", canvasReference, CurrentGraph);
    }

    private async Task SetView(DetailView view)
    {
        activeView = view;

        if (view == DetailView.Graph)
        {
            _lastTopic = null;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task OnGraphSelected(ChangeEventArgs e)
    {
        if (e.Value is null)
            return;

        if (!int.TryParse(e.Value.ToString(), out var index))
            return;

        if (index < 0 || index >= Graphs.Count)
            return;

        _lastTopic = null;
        await CurrentGraphChanged.InvokeAsync(Graphs[index]);
        await InvokeAsync(StateHasChanged);
    }

    private enum DetailView
    {
        Citations,
        Graph
    }
}