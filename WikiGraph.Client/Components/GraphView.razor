@foreach (var graph in Graphs)
{
    <div class="graph" id="graphs">
        <h3>@graph.Topic</h3>
        <div class="nodes">
            @foreach (var node in graph.Nodes)
            {
                <span class="node">@node.Label</span>
            }
        </div>
        <div class="edges">
            @foreach (var edge in graph.Edges)
            {
                <div class="edge">@ResolveLabel(graph, edge.Source) <span>@edge.Relation</span> @ResolveLabel(graph, edge.Target)</div>
            }
        </div>
    </div>
}

@if (Graphs.Count == 0)
{
    <p class="muted">Topic graphs appear once the assistant has generated session context.</p>
}

@code {
    [Parameter]
    public IReadOnlyList<GraphDto> Graphs { get; set; } = [];

    private static string ResolveLabel(GraphDto graph, string nodeId) =>
        graph.Nodes.FirstOrDefault(node => node.Id == nodeId)?.Label ?? nodeId;
}
