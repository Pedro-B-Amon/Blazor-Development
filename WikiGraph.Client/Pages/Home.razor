@page "/"
@inject ApiClient ApiClient

<PageTitle>WikiGraph</PageTitle>

<section class="card">
    <div class="hero-copy">
        <p class="eyebrow">Wikipedia research Assistant</p>
        <h1>Prompt to have a comprehensive summary of a topic</h1>
        <p class="hero-text">store citations, related topics, and summaries in one centralized workspace</p>
    </div>
    <div class="hero-actions">
        <button class="send" @onclick="RunDemo" disabled="@isBusy">Try demo prompt</button>
        <p class="hero-note">Client API target <code>http://localhost:5052</code></p>
    </div>
</section>

<div class="workspace-grid">
    <ChatSidebar Sessions="sessions" SelectedSessionId="@selectedSessionId" OnSelectSession="HandleSessionSelected" />

    <ChatThread Messages="messages"
                Prompt="@prompt"
                PromptChanged="OnPromptChanged"
                SourceUrl="@sourceUrl"
                SourceUrlChanged="OnSourceUrlChanged"
                IsBusy="isBusy"
                ErrorMessage="@errorMessage"
                OnSubmit="SubmitPrompt" />

    <section class="detail-column">
        <section class="card detail-card">
            <div class="panel-header">
                <div>
                    <p class="eyebrow">Sources</p>
                    <h2>Citations</h2>
                </div>
                <span class="count-pill">@citations.Count</span>
            </div>
            <CitationList Citations="citations" />
        </section>

        <section class="card detail-card" id="graphs">
            <div class="panel-header">
                <div>
                    <p class="eyebrow">Knowledge view</p>
                    <h2>Topic graphs</h2>
                </div>
                <span class="count-pill">@graphs.Count</span>
            </div>
            <GraphView Graphs="graphs" />
        </section>
    </section>
</div>

@code {
    @* TODO:
        - make Home.Razor more of a landing page (much more bare bones, just a search prompt and sessions)
        - Move and tweak some of the current razor code to Session.Razor 
            - Session Rendering
            - Reloading Pages
            - Session Ownership*@
    private readonly List<SessionSummary> sessions = [];
    private readonly List<MessageDto> messages = [];
    private readonly List<CitationDto> citations = [];
    private readonly List<GraphDto> graphs = [];
    private string? selectedSessionId;
    private bool isBusy;
    private string? errorMessage;
    private string prompt = string.Empty;
    private string sourceUrl = string.Empty;

    protected override Task OnInitializedAsync() => RunBusyStateAsync(LoadSessions);

    private async Task LoadSessions()
    {
        var result = await ApiClient.GetSessionsAsync();
        sessions.Clear();
        sessions.AddRange(result);

        if (sessions.Count == 0)
        {
            selectedSessionId = null;
            ClearSessionArtifacts();
            return;
        }

        if (string.IsNullOrWhiteSpace(selectedSessionId) || sessions.All(session => session.SessionId != selectedSessionId))
        {
            await LoadSession(sessions[0].SessionId);
        }
    }

    private Task HandleSessionSelected(string sessionId) => RunBusyStateAsync(() => LoadSession(sessionId));

    private async Task LoadSession(string sessionId)
    {
        var session = await ApiClient.GetSessionAsync(sessionId);
        if (session is null)
        {
            return;
        }

        selectedSessionId = sessionId;
        ReplaceSessionArtifacts(session);
    }

    private async Task SubmitPrompt()
    {
        if (string.IsNullOrWhiteSpace(prompt) && string.IsNullOrWhiteSpace(sourceUrl))
        {
            return;
        }

        await RunBusyStateAsync(async () =>
        {
            var sessionId = await EnsureSelectedSessionAsync();
            var normalizedPrompt = prompt.Trim();
            var normalizedUrl = sourceUrl.Trim();
            var payload = await ApiClient.AddArticleAsync(
                sessionId,
                new AddWikiArticleRequest(
                    normalizedPrompt,
                    string.IsNullOrWhiteSpace(normalizedUrl) ? null : normalizedUrl));

            if (payload is null)
            {
                return;
            }

            prompt = string.Empty;
            sourceUrl = string.Empty;

            ReplaceSessionArtifacts(payload);
            await LoadSessions();
        });
    }

    private async Task RunDemo()
    {
        prompt = "Climate adaptation";
        sourceUrl = string.Empty;
        await SubmitPrompt();
    }

    private Task OnPromptChanged(string value)
    {
        prompt = value;
        return Task.CompletedTask;
    }

    private Task OnSourceUrlChanged(string value)
    {
        sourceUrl = value;
        return Task.CompletedTask;
    }

    private async Task<string> EnsureSelectedSessionAsync()
    {
        if (!string.IsNullOrWhiteSpace(selectedSessionId))
        {
            return selectedSessionId;
        }

        var titleSeed = string.IsNullOrWhiteSpace(prompt) ? sourceUrl : prompt;
        var session = await ApiClient.CreateSessionAsync(new CreateSessionRequest(InferTitle(titleSeed)));
        selectedSessionId = session.SessionId;
        return session.SessionId;
    }

    private void ReplaceSessionArtifacts(SessionDetailDto session)
    {
        ClearSessionArtifacts();
        messages.AddRange(session.Messages);
        citations.AddRange(session.Citations);
        graphs.AddRange(session.Graphs);
    }

    private void ClearSessionArtifacts()
    {
        messages.Clear();
        citations.Clear();
        graphs.Clear();
    }

    private async Task RunBusyStateAsync(Func<Task> action)
    {
        isBusy = true;
        errorMessage = null;

        try
        {
            await action();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine(ex);
            errorMessage = "Unable to reach the WikiGraph API. Start the backend on http://localhost:5052 and try again.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private static string InferTitle(string value)
    {
        if (Uri.TryCreate(value, UriKind.Absolute, out var uri))
        {
            var segment = uri.Segments.LastOrDefault()?.Trim('/');
            if (!string.IsNullOrWhiteSpace(segment))
            {
                value = Uri.UnescapeDataString(segment.Replace('_', ' '));
            }
        }

        var title = value.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).Take(5);
        return string.Join(' ', title).Trim() is { Length: > 0 } result ? result : "New session";
    }
}
